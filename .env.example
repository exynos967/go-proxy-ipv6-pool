# Go Proxy IPV6 Pool 配置示例
#
# 注意：
# 1. 程序启动时会自动尝试加载当前工作目录下的 .env 文件。
# 2. 默认配置只从 .env 读取；命令行参数优先级高于 .env。
# 3. 如果启用鉴权，用户名和密码必须同时设置；两者都留空则表示关闭鉴权。
#
# 典型用法：
#   cp .env.example .env
#   vi .env
#   go run .

# HTTP 代理监听端口。
# SOCKS5 端口会自动使用 PORT + 1，例如这里会监听 52123。
PORT=52122

# 代理出口使用的 IPv6 子网，必须替换成你自己的已可用前缀。
CIDR=2a03:4000:4d:e7a::/64

# 单次请求并发尝试的随机 IPv6 数量。
# 谁先 TCP 建连成功就使用谁；默认 5。
DIAL_PARALLELISM=5

# 单个 candidate 的 TCP 建连超时，单位毫秒。
# 值越小，坏链路拖累越轻；值过小也可能误伤正常慢链路。
DIAL_TIMEOUT_MS=5000

# IPv6 DNS 缓存 TTL，单位秒。
# 设为 0 表示关闭缓存；短 TTL 可以兼顾时效性和解析速度。
DNS_CACHE_TTL_SECONDS=30

# HTTP / SOCKS5 统一鉴权用户名。
# 留空表示不启用鉴权。
PROXY_USERNAME=

# HTTP / SOCKS5 统一鉴权密码。
# 与 PROXY_USERNAME 配对使用，不能只填一个。
PROXY_PASSWORD=
